# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Clerk URL config (no /folio prefix needed — Next.js basePath handles it)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/build
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/build

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Dodo Payments
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_RETURN_URL=https://afterapp.fun/folio/build
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PRODUCT_PRO=
DODO_PRODUCT_AGENCY=

# Services
PROXYCURL_API_KEY=
ANTHROPIC_API_KEY=

# Vercel Deploy (for deploying user sites)
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=

# App
NEXT_PUBLIC_APP_URL=https://afterapp.fun/folio
